import yfinance as yf
from quantix.A_Strategy import PullbackStrategy
from quantix.A_BackTest import Backtester

ticker = "TSLA"
data = yf.download(ticker, start="2025-01-01", end="2026-01-01", auto_adjust=False)

data = data[["Open", "High", "Low", "Close", "Volume"]].dropna()

strategy = PullbackStrategy(data)
strategy.generate_signals()

bt = Backtester(strategy)
results = bt.backtest(stop_loss_pct=0.08)

print(bt.stats())
print(
    results[
        [
            "Close",
            "signal",
            "position",
            "cumulative_strategy_return",
            "cumulative_buy_and_hold_return",
        ]
    ].tail()
)
print(bt.trades[-5:])
