# Buy TSLA when the long-term trend is up, a short-term pullback has happened, and momentum starts to recover. Sell on overbought conditions, trend weakness, or a fixed loss using stop losses.
# Use RSI (Relative Strength Index) which is a popular momentum indicator.

import sys
import os

sys.path.insert(0, os.path.abspath(os.path.join(os.path.dirname(__file__), "..")))

import yfinance as yf
import pandas as pd
import matplotlib.pyplot as plt

from quantix.A_Strategy import PullbackStrategy
from quantix.A_BackTest import Backtester

ticker = "TSLA"
data = yf.download(ticker, start="2025-01-01", end="2026-01-01", auto_adjust=False)

if isinstance(data.columns, pd.MultiIndex):
    data.columns = data.columns.droplevel("Ticker")

data = data[["Open", "High", "Low", "Close", "Volume"]].dropna()

strategy = PullbackStrategy(data)
strategy.generate_signals()

bt = Backtester(strategy)
results = bt.backtest(stop_loss_pct=0.08)

print(bt.stats())
print(results[["Close", "signal", "position", "strategy_return"]].tail())
print(bt.trades[-5:])
